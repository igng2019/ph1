
"smart_sources:학문/철학/철학사/철학/서양 철학/철학사/자율적 시대/현대철학/현대 대륙철학/구조주의/포스트 모더니즘/유목 철학/들뢰즈/푸코/1.역사적 형성작용 또는 지층-가시적인 것과 언표 가능한 것 - 지식.md": {"path":"학문/철학/철학사/철학/서양 철학/철학사/자율적 시대/현대철학/현대 대륙철학/구조주의/포스트 모더니즘/유목 철학/들뢰즈/푸코/1.역사적 형성작용 또는 지층-가시적인 것과 언표 가능한 것 - 지식.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"sicnn3","at":1775762793286},"class_name":"SmartSource","last_import":{"mtime":1772625184162,"size":4500,"at":1775762793288,"hash":"sicnn3"},"blocks":{"#1．지층은 가시성과 언표 가능성의 조합이다":[1,28],"#1．지층은 가시성과 언표 가능성의 조합이다##● 재영토화":[3,12],"#1．지층은 가시성과 언표 가능성의 조합이다##● 재영토화#{1}":[5,12],"#1．지층은 가시성과 언표 가능성의 조합이다##● 탈영토화":[13,28],"#1．지층은 가시성과 언표 가능성의 조합이다##● 탈영토화#{1}":[15,28],"#2．가시성과 언표는 시대마다 재조합된다":[29,54],"#2．가시성과 언표는 시대마다 재조합된다##● 재영토화":[31,38],"#2．가시성과 언표는 시대마다 재조합된다##● 재영토화#{1}":[33,38],"#2．가시성과 언표는 시대마다 재조합된다##● 탈영토화":[39,54],"#2．가시성과 언표는 시대마다 재조합된다##● 탈영토화#{1}":[41,54],"#3．푸코는 초기에는 언표의 우위에 집중했지만, 이는 환원이 아니다":[55,78],"#3．푸코는 초기에는 언표의 우위에 집중했지만, 이는 환원이 아니다##● 재영토화":[57,62],"#3．푸코는 초기에는 언표의 우위에 집중했지만, 이는 환원이 아니다##● 재영토화#{1}":[59,62],"#3．푸코는 초기에는 언표의 우위에 집중했지만, 이는 환원이 아니다##● 탈영토화":[63,78],"#3．푸코는 초기에는 언표의 우위에 집중했지만, 이는 환원이 아니다##● 탈영토화#{1}":[65,78],"#4．가시성과 언표는 각각 고유한 형식이며, 서로를 침투한다":[79,106],"#4．가시성과 언표는 각각 고유한 형식이며, 서로를 침투한다##● 재영토화":[81,90],"#4．가시성과 언표는 각각 고유한 형식이며, 서로를 침투한다##● 재영토화#{1}":[83,90],"#4．가시성과 언표는 각각 고유한 형식이며, 서로를 침투한다##● 탈영토화":[91,106],"#4．가시성과 언표는 각각 고유한 형식이며, 서로를 침투한다##● 탈영토화#{1}":[93,106],"#5．두 형식은 동형성도 인과성도 없지만, 서로를 전투적으로 관통한다":[107,130],"#5．두 형식은 동형성도 인과성도 없지만, 서로를 전투적으로 관통한다##● 재영토화":[109,114],"#5．두 형식은 동형성도 인과성도 없지만, 서로를 전투적으로 관통한다##● 재영토화#{1}":[111,114],"#5．두 형식은 동형성도 인과성도 없지만, 서로를 전투적으로 관통한다##● 탈영토화":[115,130],"#5．두 형식은 동형성도 인과성도 없지만, 서로를 전투적으로 관통한다##● 탈영토화#{1}":[117,130],"#6．결정작용은 결국 언표 측에 있지만, 가시성은 항상 저항하며 변형된다":[131,156],"#6．결정작용은 결국 언표 측에 있지만, 가시성은 항상 저항하며 변형된다##● 재영토화":[133,138],"#6．결정작용은 결국 언표 측에 있지만, 가시성은 항상 저항하며 변형된다##● 재영토화#{1}":[135,138],"#6．결정작용은 결국 언표 측에 있지만, 가시성은 항상 저항하며 변형된다##● 탈영토화":[139,156],"#6．결정작용은 결국 언표 측에 있지만, 가시성은 항상 저항하며 변형된다##● 탈영토화#{1}":[141,156],"#7．둘 사이의 간극을 설명하는 제3의 심급: 비정형적 차원(다이어그램적 축)":[157,183],"#7．둘 사이의 간극을 설명하는 제3의 심급: 비정형적 차원(다이어그램적 축)##● 재영토화":[159,168],"#7．둘 사이의 간극을 설명하는 제3의 심급: 비정형적 차원(다이어그램적 축)##● 재영토화#{1}":[161,168],"#7．둘 사이의 간극을 설명하는 제3의 심급: 비정형적 차원(다이어그램적 축)##● 탈영토화":[169,183],"#7．둘 사이의 간극을 설명하는 제3의 심급: 비정형적 차원(다이어그램적 축)##● 탈영토화#{1}":[171,183]},"outlinks":[],"task_lines":[],"tasks":{},"codeblock_ranges":[]},
