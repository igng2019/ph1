%A0%EC%9E%90%EB%A3%8C/%ED%95%99%EC%88%A0%EC%9E%90%EB%A3%8C%20%EB%8F%84%EC%84%9C/%EC%A7%80%ED%96%A5%EC%84%B1%20%EA%B0%9C%EB%85%90-%ED%9B%84%EC%84%A4%EC%9D%98%20%EB%B8%8C%EB%A0%8C%ED%83%80%EB%85%B8%20%EB%B9%84%ED%8C%90%EC%9D%84%20%EC%A4%91%EC%8B%AC%EC%9C%BC%EB%A1%9C/%25EC%25A7%2580%25ED%2596%25A5%25EC%2584%25B1_%25EA%25B0%259C%25EB%2585%2590__%25ED%259B%2584%25EC%2584%25A4%25EC%259D%2598_%25EB%25B8%258C%25EB%25A0%258C%25ED%2583%2580%25EB%2585%25B8_%25EB%25B9%2584%25ED%258C%2590%25EC%259D%2584_%25EC%25A4%2591%25EC%258B%25AC%25EC%259C%25BC%25EB%25A1%259C.pdf"],"State":"Done"},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"Notion/ee36cb63c8e4491a8077e3323bd40b1b/지향성 개념-후설의 브렌타노 비판을 중심으로.md","last_embed":{"hash":"1yaqcei","at":1772607058518}},"smart_blocks:Notion/ee36cb63c8e4491a8077e3323bd40b1b/지향성 개념-후설의 브렌타노 비판을 중심으로.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.03574148,-0.03607463,0.03722829,-0.03631555,-0.00336901,0.01344482,0.01119419,0.03172862,0.01794202,-0.00496731,0.00472669,-0.07119429,0.04056619,-0.00224355,0.03838286,-0.02074462,0.02970543,0.00972835,-0.08340012,0.01545596,0.19004081,-0.05412307,0.00843084,-0.00268702,-0.02937655,0.02752765,0.00335225,-0.04431745,-0.0094067,-0.15325595,-0.04387872,0.01050306,0.12662564,0.02981146,-0.00395323,0.0104797,-0.029651,0.08137519,-0.10297002,0.01714334,0.00753792,-0.00202783,0.04529528,-0.05012451,-0.01174065,-0.03710523,0.00780055,0.02056522,-0.04840692,-0.04955178,0.01082261,-0.05197472,-0.00641384,0.01291498,0.02115379,0.04045362,0.03473619,-0.00070395,0.06042332,0.01841076,0.0762479,0.06763209,-0.21317966,0.02804315,0.01753179,0.02011243,-0.01706563,-0.0749409,0.03827245,0.07389031,0.00008797,0.02190426,0.00136678,0.0613056,-0.01633118,-0.00060707,0.00499576,0.00130508,-0.04410022,-0.05471404,-0.02652305,0.05020945,-0.00633103,-0.02217207,-0.00609692,0.01705374,-0.03189981,-0.00656418,0.00672791,0.01199371,-0.04332574,-0.01846742,0.01573276,-0.03680058,-0.05399013,