7%80%20&%20%EA%B3%B5%EC%9C%A0%EB%90%9C%20%ED%8E%98%EC%9D%B4%EC%A7%80/%EC%B2%A0%ED%95%99%20%EC%84%B8%EB%AF%B8%EB%82%98%20(1)/Capella%EB%8B%98%EC%9D%98%20%EC%82%AC%EC%9C%A0%ED%8E%98%EC%9D%B4%EC%A7%80/%ED%95%99%EC%88%A0%EC%9E%90%EB%A3%8C/%ED%95%99%EC%88%A0%EC%9E%90%EB%A3%8C%20%EB%8F%84%EC%84%9C/%EC%9D%B4%EB%8D%B0%EC%95%84%EC%99%80%20%EC%97%90%EC%9D%B4%EB%8F%84%EC%8A%A4%20%EA%B0%9C%EB%85%90%EA%B5%AC%EB%B6%84%EC%97%90%20%EA%B4%80%ED%95%98%EC%97%AC(%EC%88%98%EC%A0%95%EC%99%84%EB%A3%8C)/KCI_FI001158450.pdf"],"State":"Done"},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"Notion/ee36cb63c8e4491a8077e3323bd40b1b/이데아와 에이도스 개념구분에 관하여(수정완료).md","last_embed":{"hash":"12x2ulm","at":1772607017945}},"smart_blocks:Notion/ee36cb63c8e4491a8077e3323bd40b1b/이데아와 에이도스 개념구분에 관하여(수정완료).md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02957126,-0.03450491,0.03805875,-0.03908157,0.00134687,0.00975947,0.02302338,0.0281908,0.01997598,0.0024976,0.00350009,-0.06574794,0.03411942,-0.00286672,0.04209778,-0.01869253,0.02316378,0.00876703,-0.08232464,0.01384837,0.1860918,-0.05644457,0.00891886,0.00465107,-0.02518295,0.0282273,0.00242836,-0.05150563,-0.0105499,-0.14990589,-0.03651982,0.00869463,0.12803249,0.03530415,-0.00148014,0.01151676,-0.02684832,0.08466621,-0.10168746,0.01711297,0.00763635,-0.00647986,0.04897679,-0.04611731,-0.01734282,-0.03827597,0.0000827,0.01457638,-0.05798177,-0.05544671,0.00182776,-0.0571048,-0.00438068,0.01393551,0.01066897,0.03378884,0.03460926,0.00252284,0.06111434,0.03077349,0.07848819,0.07265805,-0.21324027,0.03777406,0.02225058,0.01676327,-0.01288239,-0.06887618,0.03468168,0.07128694,-0.00542606,0.01772207,0.00912244,0.06468496,-0.02156333,-0.00723223,0.0015529,0.00560645,-0.04367305,-0.05190952,-0.02414634,0.0546127,0.00044647,-0.026154,-0.01331637,0.0233498,-0.0386982,-0.00777051,0.00916184,0.01178341,-0.03947008,-0.02706861,0.01218285,-0.03114878,-0.05032727,-0.0164988,0.01561294,0.04645134,-0.04591909,0.12076905,-0.03710