,-0.00752567,-0.0083071,0.0307395,-0.04572617,0.03397327,-0.04521867,0.08692446,-0.00524861,0.02110152,0.0727929,0.24350996,-0.02805509,0.01913751,0.03019162,0.03229236,0.03830492,0.03624889,-0.01485701,-0.04894817,0.03134412,0.0967221,0.01172616,-0.01363772,0.04125015,-0.02093884,0.00308554,0.05207862,0.01469491,-0.03359188,0.00827013,-0.01504616,-0.00629862,0.11686392,0.00162279,-0.02835742,-0.04674047,0.01361174,0.03899815,0.03497349,-0.00411607,-0.04172082,0.02568571,0.02479817,0.061484,0.02685271,0.02211027,-0.04502571,-0.03283832,0.00971883,-0.01495928,0.02317806,0.05039346,0.0497913],"last_embed":{"hash":"17af7ur","tokens":453}}},"last_read":{"hash":"17af7ur","at":1772607111485},"class_name":"SmartSource","last_import":{"mtime":1772601064589,"size":10973,"at":1772606281167,"hash":"17af7ur"},"blocks":{"#---frontmatter---":[1,10],"###들어가는 말":[13,42],"###들어가는 말#{1}":[17,42],"###하이데거의 실존과 타자개념":[43,92],"###하이데거의 실존과 타자개념#{1}":[47,92],"###사르트르의 타자개념":[93,142],"###사르트르의 타자개념#{1}":[97,142],"###나가는 말":[143,167],"###나가는 말#{1}":[147,167]},"outlinks":[],"metadata":{"Autor":"이서규/한국동서철학","Keyword":["사르트르","하이데거"],"Detail":"- 하이데거는 각자성이라는 현존재의 특성을 통해 눈 앞의 대상과는 다른 방식으로 존재하는 타자의 가능성을 드러내주었다. 이는 유아론을 방어할 수 있는 하이데거의 입장이다.- 사르트르는후설의 현존개념을 적극 수용하여 무의 개념을 통해 즉자에서 대자로 이행하는 존재, 그리고 또 하나의 대자인 타자를 언급하며 타인의 시선에 의해 끊임없이 위협받으며 존재의 지평을 상실하는 파국적인 존재방식을 밝혀낸다. 타유화는 또다른 유아론의 단초이기도 하다.","PDF":["../../../../../../%EA%B0%9C%EC%9D%B8%20%ED%8E%98%EC%9D%B4%EC%A7%80%20&%20%EA%B3%B5%EC%9C%A0%EB%90%9C%20%ED%8E%98%EC%9D%B4%EC%A7%80/%EC%B2%A0%ED%95%99%20%EC%84%B8%EB%AF%B8%EB%82%98%20(1)/Capella%EB%8B%98%EC%9D%98%20%EC%82%AC%EC%9C%A0%ED%8E%98%EC%9D%B4%EC%A7%80/%ED%95%99%EC%88%A0%EC%9E%90%EB%A3%8C/%ED%95%99%EC%88%A0%EC%9E%90%EB%A3%8C%20%EB%8F%84%EC%84%9C/%ED%95%98%EC%9D%B4%EB%8D%B0%EA%B1%B0%EC%99%80%20%EC%82%AC%EB%A5%B4%ED%8A%B8%EB%A5%B4%EC%9D%98%20%ED%83%80%EC%9E%90%EA%B0%9C%EB%85%90%EC%97%90%20%EB%8C%80%ED%95%9C%20%EA%B3%A0%EC%B0%B0(%EC%88%98%EC%A0%95%EC%99%84%EB%A3%8C)/%25ED%2595%2598%25EC%259D%25B4%25EB%258D%25B0%25EA%25B1%25B0%25EC%2599%2580_%25EC%2582%25AC%25EB%25A5%25B4%25ED%258A%25B8%25EB%25A5%25B4%25EC%259D%2598_%25ED%2583%2580%25EC%259E%2590%25EA%25B0%259C%25EB%2585%2590%25EC%2597%2590_%25EB%258C%2580%25ED%2595%259C_%25EA%25B3%25A0%25EC%25B0%25B0.pdf"],"State":"Done"},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"Notion/ee36cb63c8e4491a8077e3323bd40b1b/하이데거와 사르트르의 타자개념에 대한 고찰(수정완료).md","last_embed":{"hash":"17af7ur","at":1772607111485}},"smart_blocks:Notion/ee36cb63c8e4491a8077e3323bd40b1b/하이데거와 사르트르의 타자개념에 대한 고찰(수정완료).md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.03145456,-0.04181898,0.03944936,-0.03988119,0.00626645,0.01334377,0.0117485,0.03460368,0.01394469,-0.00002153,0.01094743,-0.06351182,0.03522408,-0.01346277,0.03589088,-0.01930735,0.0225728,0.01421003,-0.07500973,0.01638161,0.19019613,-0.0505926,0.0094995,0.00159318,-0.0314684,0.03469589,0.00019376,-0.04737193,-0.01315542,-0.1597506,-0.03557033,0.00819838,0.13386546,0.03017523,-0.00276268,0.01124734,-0.0231151,0.08722942,-0.10261317,0.01741598,0.003413,-0.00572813,0.04970046,-0.04528794,-0.01810889,-0.03988625,0.00356856,0.01697198,-0.05646452,-0.05102243,0.00836364,-0.05102313,-0.00420698,0.00588229,0.01382271,0.03898296,0.0274747,-0.00090877,0.05984237,0.02464498,0.07194561,0.07291151,-0.21719754,0.04300071,0.02777624,0.022351,-0.01646579,-0.07087342,0.0349988,0.06932461,-0.00598265,0.01754263,0.01194308,0.05945892,-0.01862545,-0.00694182,0.00112211,0.00488805,-0.0435074,-0.05215206,-0.02403858,0.05804788,0.00208131,-0.02964581,-0.00766484,0.01325868,-0.04249157,-0.01065647,0.00948143,0.0160575,-0.04023929,-0.02719693,0.01039285,-0.03396291,-0.05218445,-0.02325802,0.01516558,0.04603674,-0.04722419,0.11816989,-0.03753441,0.04853222,0.03426781,-0.05820393,0.04675892,-0.06924153,0.0004182,-0.13284647,-0.00040764,-0.01863007,-0.04404515,-0.03234006,-0.00716438,-0.02177913,0.02301725,0.01895353,0.05578513,-0.0082175,0.02246647,-0.01017013,0.01847761,0