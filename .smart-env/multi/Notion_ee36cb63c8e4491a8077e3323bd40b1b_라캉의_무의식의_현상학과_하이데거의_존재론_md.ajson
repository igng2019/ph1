-0.00837635,0.02378199,-0.05928674,0.03872471,-0.04316637,0.07120873,-0.02246062,0.00647322,0.07652957,0.23610289,-0.03521379,0.00439192,0.01866945,0.03120783,0.04479957,0.05382758,-0.02306088,-0.04458876,0.03216995,0.1021835,0.02007428,-0.0063046,0.04165165,-0.01302555,-0.00582527,0.03258993,0.00196513,-0.03484661,0.01613368,-0.02095702,-0.00458061,0.12018025,-0.00864054,-0.04662736,-0.04249592,0.02187815,0.03621299,0.04598494,0.000298,-0.05025947,0.03597418,0.01622353,0.0622535,0.01822525,0.01918184,-0.04464909,-0.02218482,-0.00418564,-0.00363409,0.01768227,0.05913864,0.05460929],"last_embed":{"hash":"57oxpv","tokens":509}}},"last_read":{"hash":"57oxpv","at":1772606855117},"class_name":"SmartSource","last_import":{"mtime":1772601063513,"size":12778,"at":1772606281166,"hash":"57oxpv"},"blocks":{"#---frontmatter---":[1,11],"###라캉의 무의식의 현상학":[12,45],"###라캉의 무의식의 현상학#{1}":[14,35],"###라캉의 무의식의 현상학#{2}":[36,37],"###라캉의 무의식의 현상학#{3}":[38,39],"###라캉의 무의식의 현상학#{4}":[40,45],"###무의식의 언어화":[46,79],"###무의식의 언어화#{1}":[48,79],"###**오이디푸스 콤플렉스 재해석, 상상계/상징계/실재계**":[80,145],"###**오이디푸스 콤플렉스 재해석, 상상계/상징계/실재계**#{1}":[82,145],"###**라캉 vs 하이데거: 무의식의 언어 vs 존재의 언어**":[146,222],"###**라캉 vs 하이데거: 무의식의 언어 vs 존재의 언어**#{1}":[148,222]},"outlinks":[],"metadata":{"Autor":"박유정/문화와융합","Keyword":["라캉","프로이트","하이데거"],"Detail":"-라캉의 무의식의 현상학의 세 가지 특징1) 무의식의 언어화2) 오이디푸스 콤플렉스의 재해석3) 상상계/상징계/실재계 개념으로 구성-정신분석의 대상은 무의식의 분열된 주체이며 언어적 상징구조로 해석된다.-팔루스는 주체의 욕망을 채워준다고 가정되는 무엇에 대한 상징이며 그 자체가 기표-상상계는 어머니와의 폐쇄적 이자관계, 서로가 서로의 팔루스가 되어줌/거울단계에서 자아는 이미지가 허상임을 깨닫고 깨어지는 거세 과정을 겪으며 상징계로, 아버지의 이름을 받아들이는 삼자관계로 이행/실재계는 상징화되지 못하고 남아 있는 잔여분-하이데거와의 공통점 : 언어는 우리의 주체를 빚어내고 우리는 언어 속으로 태어난다.-하이데거와의 차이점 : 언어가 열어 밝히는 것이 라캉에게는 인간의 통제를 벗어난 무의식, 하이데거의 정적인 언어와 다른 세계로 인도","PDF":["../../../../../../%EA%B0%9C%EC%9D%B8%20%ED%8E%98%EC%9D%B4%EC%A7%80%20&%20%EA%B3%B5%EC%9C%A0%EB%90%9C%20%ED%8E%98%EC%9D%B4%EC%A7%80/%EC%B2%A0%ED%95%99%20%EC%84%B8%EB%AF%B8%EB%82%98%20(1)/Capella%EB%8B%98%EC%9D%98%20%EC%82%AC%EC%9C%A0%ED%8E%98%EC%9D%B4%EC%A7%80/%ED%95%99%EC%88%A0%EC%9E%90%EB%A3%8C/%ED%95%99%EC%88%A0%EC%9E%90%EB%A3%8C%20%EB%8F%84%EC%84%9C/%EB%9D%BC%EC%BA%89%EC%9D%98%20%EB%AC%B4%EC%9D%98%EC%8B%9D%EC%9D%98%20%ED%98%84%EC%83%81%ED%95%99%EA%B3%BC%20%ED%95%98%EC%9D%B4%EB%8D%B0%EA%B1%B0%EC%9D%98%20%EC%A1%B4%EC%9E%AC%EB%A1%A0/KBB_SCHOLAR_%25EB%259D%25BC%25EC%25BA%2589%25EC%259D%2598%25EB%25AC%25B4%25EC%259D%2598%25EC%258B%259D%25EC%259D%2598%25ED%2598%2584%25EC%2583%2581%25ED%2595%2599%25EA%25B3%25BC%25ED%2595%2598%25EC%259D%25B4%25EB%258D%25B0%25EA%25B1%25B0%25EC%259D%2598%25EC%25A1%25B4%25EC%259E%25AC%25EB%25A1%25A0.pdf"],"State":"Done"},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"Notion/ee36cb63c8e4491a8077e3323bd40b1b/라캉의 무의식의 현상학과 하이데거의 존재론.md","last_embed":{"hash":"57oxpv","at":1772606855117}},"smart_blocks:Notion/ee36cb63c8e4491a8077e3323bd40b1b/라캉의 무의식의 현상학과 하이데거의 존재론.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.03468173,-0.04346555,0.02787222,-0.04062331,0.00344217,0.01726441,0.01512423,0.03431474,0.01829836,0.00310832,0.0032188,-0.05805182,0.02924225,-0.01387518,0.0392922,-0.02336736,0.02313145,0.02318116,-0.07372932,0.02238763,0.18076563,-0.05537957,0.0031789,0.00312734,-0.03333937,0.02658801,0.00304918,-0.04660414,-0.01580041,-0.16032481,-0.03077999,0.0000413,0.13404427,0.02628259,0.00239613,0.00281934,-0.01782488,0.08922091,-0.10401075,0.01231368,0.00274338,-0.00343884,0.04346589,-0.0355556,-0.01893108,-0.03845545,0.00405212,0.02231305,-0.06092008,-0.05419309,0.00937195,-0.05444768,-0.00233362,0.00571666,0.00962586,0.0449652,0.02942246,0.00079182,0.05326128,0.03033273,0.07362595,0.06900256,-0.22942849,0.04828938,0.03351192,0.02902312,-0.02592479,-0.08226357,0.03893525,0.06964367,-0.01028666,0.01188787,0.00086077,0.06185759,-0.01494351,-0.00256061,0.00408309,0.00272243,-0.04598824,-0.04900362,-0.0165231,0.0473303,-0.0059733,-0.0259352,-0.00862733,0.0193932,-0.03863556,-0.01881316,0.00375578,0.01286446,-0.05198929,-0.03076208,0.00828685,-0.03161103,-0.05