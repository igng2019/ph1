4/%25EC%25B2%25A0%25ED%2595%2599_%25EC%259E%2585%25EB%25AC%25B8%25EC%259D%2584_%25EC%259C%2584%25ED%2595%259C_10%25EA%25B0%259C%25EC%259D%2598_%25ED%2582%25A4%25EC%259B%258C%25EB%2593%259C_04.pdf","../../../../../../%EA%B0%9C%EC%9D%B8%20%ED%8E%98%EC%9D%B4%EC%A7%80%20&%20%EA%B3%B5%EC%9C%A0%EB%90%9C%20%ED%8E%98%EC%9D%B4%EC%A7%80/%EC%B2%A0%ED%95%99%20%EC%84%B8%EB%AF%B8%EB%82%98%20(1)/Capella%EB%8B%98%EC%9D%98%20%EC%82%AC%EC%9C%A0%ED%8E%98%EC%9D%B4%EC%A7%80/%ED%95%99%EC%88%A0%EC%9E%90%EB%A3%8C/%ED%95%99%EC%88%A0%EC%9E%90%EB%A3%8C%20%EB%8F%84%EC%84%9C/%EC%8B%A4%EC%9E%AC%20%EC%8B%A4%EC%B2%B4%20%EC%8B%A4%EC%A0%9C%20%EC%B0%A8%EC%9D%B4/%25EB%25B0%259C%25ED%2591%259C%25EB%25AC%25B8_9._%25EA%25B9%2580%25EC%259A%25A9%25ED%2595%25B4__%25EC%258B%25A4%25EC%259E%25AC%25EB%259E%2580_%25EB%25AC%25B4%25EC%2597%2587%25EC%259D%25B8%25EA%25B0%2580_%25EC%2588%2598%25EC%25A0%2595.hwp"],"State":"Done"},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"Notion/ee36cb63c8e4491a8077e3323bd40b1b/실재-실체-실제 차이.md","last_embed":{"hash":"1q5ox4o","at":1772606983357}},"smart_blocks:Notion/ee36cb63c8e4491a8077e3323bd40b1b/실재-실체-실제 차이.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.04278681,-0.04687964,0.03252843,-0.04661903,-0.00882432,0.01245572,0.01520767,0.0285115,0.03526063,-0.00173657,0.00970204,-0.06780319,0.0378641,-0.00331192,0.04020618,-0.02216688,0.01848563,0.01748694,-0.09468035,0.01652964,0.18762888,-0.05223988,0.00793032,0.01078722,-0.03161931,0.0353634,-0.0045628,-0.05111783,-0.01427434,-0.17195188,-0.04171681,0.00015522,0.119699,0.02560781,0.00153538,0.00517222,-0.03495947,0.07914167,-0.09944544,0.02365382,0.00641619,-0.00555006,0.04695744,-0.03832396,-0.02776301,-0.04701034,0.00009122,0.02597336,-0.05149246,-0.04880666,0.01216759,-0.05116737,0.00302264,0.00679705,0.01145759,0.04157156,0.02529444,0.01131262,0.05304804,0.02753829,0.06249406,0.06683543,-0.20210013,0.03457858,0.01738527,0.01905219,-0.00877533,-0.08527584,0.04203383,0.06317469,-0.00